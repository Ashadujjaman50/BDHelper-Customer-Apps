<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for Night Mode -->
    <style name="Base.Theme.BDHelper" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Dark theme colors -->
        <item name="android:colorPrimary">@color/transparent</item>
        <item name="colorSecondary">@color/secondaryColor_dark</item>
        <item name="colorAccent">@color/accentColor_dark</item>
        <item name="android:background">@color/background_dark</item>
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnPrimary">@color/on_primary_dark</item>
        <item name="colorOnSecondary">@color/on_secondary_dark</item>
        <item name="colorOnBackground">@color/on_background_dark</item>
        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="android:windowActionBarOverlay">true</item>
        <item name="android:statusBarColor" tools:targetApi="21">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.BDHelper" parent="Base.Theme.BDHelper">
        <!-- Set global font directly -->
        <item name="android:fontFamily">@font/solaimanlipi</item> <!-- ✅ for most Views -->
        <item name="fontFamily">@font/solaimanlipi</item> <!-- ✅ for some components -->

        <item name="android:background">@color/transparent</item>
        <item name="bottomNavigationStyle">@style/Widget.BottomNavigationView</item>
    </style>

    <!-- Font style remains same -->
    <style name="fontStyle" parent="Base.Theme.BDHelper">
        <item name="android:fontFamily">@font/solaimanlipi</item>
        <item name="fontFamily">@font/solaimanlipi</item>
    </style>

    <style name="BottomNavigation.ActiveItemTextAppearance" parent="TextAppearance.AppCompat">
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">@font/open_sans_regular</item>
    </style>

    <style name="Widget.BottomNavigationView" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemRippleColor">@color/nav_selected_bg_dark</item> <!-- Dark mode ripple -->
        <item name="android:background">@color/background_dark</item> <!-- Keep dark mode background -->
        <item name="background">@color/background_dark</item>
    </style>
</resources>
