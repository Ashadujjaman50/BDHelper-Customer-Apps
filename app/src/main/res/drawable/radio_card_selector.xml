<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Selected হলে -->
    <item android:state_checked="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/radio_card_selected_bg"  /> <!-- সিলেক্টেড কালার -->
            <stroke android:width="1dp" android:color="@color/radio_card_selected" />
            <corners android:radius="12dp" />
            <padding android:bottom="10dp"
                android:left="10dp"
                android:right="10dp"
                android:top="10dp"/>

        </shape>
    </item>

    <!-- Unselected হলে -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/radio_card_normal_bg" /> <!-- default -->
            <stroke android:width="1dp" android:color="@color/radio_card_normal" />
            <corners android:radius="12dp" />
            <padding android:bottom="10dp"
                android:left="10dp"
                android:right="10dp"
                android:top="10dp"/>
        </shape>
    </item>

</selector>
