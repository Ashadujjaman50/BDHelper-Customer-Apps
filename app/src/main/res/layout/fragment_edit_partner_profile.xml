<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_color"
        style="@style/fontStyle"
        tools:context=".partnerFragment.EditPartnerProfileFragment">


        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_marginTop="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:layout_marginBottom="18dp"
                    android:layout_gravity="center_horizontal">


                    <!-- Profile Image -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/userProfilePicIV"
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        android:padding="1dp"
                        android:src="@drawable/ic_profile"
                        android:background="@color/primary_light"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/ImageStyle_Circle"
                        android:layout_marginVertical="0dp"/>

                    <ImageView
                        android:id="@+id/openGalleryToLoadImage"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_circle_white"
                        android:src="@drawable/ic_camera"
                        app:tint="@color/gray" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/profileRL"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_light"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/profileIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_centerVertical="true"
                        android:background="@drawable/card_square_bg"
                        android:padding="8dp"
                        android:src="@drawable/ic_profile"
                        app:tint="@color/black" />

                    <EditText
                        android:id="@+id/userNameEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_toEndOf="@id/profileIcon"
                        android:background="@drawable/bg_edit_text"
                        android:hint="@string/name"
                        android:importantForAutofill="no"
                        android:inputType="text"
                        android:imeOptions="actionDone"
                        android:padding="10dp"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"/>

                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/divider_color" />

                <RelativeLayout
                    android:id="@+id/onlinePaymentRl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_light"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/creditIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/card_square_light_bg"
                        android:layout_centerVertical="true"
                        android:padding="8dp"
                        android:src="@drawable/ic_call_outline"
                        app:tint="@color/icon_color" />

                    <EditText
                        android:id="@+id/userMobileEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_toEndOf="@id/creditIcon"
                        android:background="@drawable/bg_edit_text"
                        android:hint="@string/mobile_number"
                        android:importantForAutofill="no"
                        android:inputType="phone"
                        android:imeOptions="actionDone"
                        android:textColor="@color/text_primary"
                        android:padding="10dp"
                        android:textSize="16sp"/>


                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/divider_color" />

                <RelativeLayout
                    android:id="@+id/businessNameRl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_light"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/shopIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/card_square_bg"
                        android:layout_centerVertical="true"
                        android:padding="8dp"
                        android:src="@drawable/ic_shop"
                        app:tint="@color/black" />

                    <EditText
                        android:id="@+id/businessNameEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_toEndOf="@id/shopIcon"
                        android:background="@drawable/bg_edit_text"
                        android:hint="@string/your_business_or_ocp_name"
                        android:importantForAutofill="no"
                        android:inputType="text"
                        android:imeOptions="actionDone"
                        android:textColor="@color/text_primary"
                        android:padding="10dp"
                        android:textSize="16sp"/>




                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/divider_color" />

                <RelativeLayout
                    android:id="@+id/emailRl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_light"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/emailIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/card_square_light_bg"
                        android:layout_centerVertical="true"
                        android:padding="8dp"
                        android:src="@drawable/ic_mail"
                        app:tint="@color/icon_color" />

                    <EditText
                        android:id="@+id/userEmailEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_toEndOf="@id/emailIcon"
                        android:background="@drawable/bg_edit_text"
                        android:hint="@string/your_email"
                        android:importantForAutofill="no"
                        android:inputType="textEmailAddress"
                        android:imeOptions="actionDone"
                        android:textColor="@color/text_secondary"
                        android:padding="10dp"
                        android:textSize="16sp"/>


                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/divider_color" />

                <RelativeLayout
                    android:id="@+id/locationRl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_light"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/mapLocationIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/card_square_bg"
                        android:layout_centerVertical="true"
                        android:padding="8dp"
                        android:src="@drawable/ic_division_location"
                        app:tint="@color/black" />

                    <EditText
                        android:id="@+id/userLocationEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_toEndOf="@id/mapLocationIcon"
                        android:background="@drawable/bg_edit_text"
                        android:hint="@string/location"
                        android:importantForAutofill="no"
                        android:imeOptions="actionDone"
                        android:textColor="@color/text_primary"
                        android:padding="10dp"
                        android:textSize="16sp" />

                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="6dp"
                    android:layout_marginHorizontal="16dp"
                    android:background="@color/divider_color" />

                <RelativeLayout
                    android:id="@+id/districtRl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_row_light"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/mapDistrictIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/card_square_light_bg"
                        android:layout_centerVertical="true"
                        android:padding="8dp"
                        android:src="@drawable/ic_location_outline"
                        app:tint="@color/icon_color" />

                    <TextView
                        android:id="@+id/userDistrictEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="10dp"
                        android:layout_toEndOf="@id/mapDistrictIcon"
                        android:background="@drawable/bg_edit_text"
                        android:hint="@string/district"
                        android:textColor="@color/text_primary"
                        android:padding="10dp"
                        android:textSize="16sp"
                        android:drawablePadding="10dp"
                        app:drawableEndCompat="@drawable/ic_arrow_drop_down" />

                </RelativeLayout>

                <LinearLayout
                    android:theme="@style/fontStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_gravity="center"
                    android:layout_marginVertical="24dp"
                    android:orientation="horizontal">


                    <TextView
                        android:id="@+id/saveBtn"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:background="@drawable/bg_button_stroke_primary"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="@string/save"
                        android:textAlignment="center"
                        android:textColor="@color/text_primary"
                        android:fontFamily="@font/solaimanlipi" />

                </LinearLayout>

            </LinearLayout>

        </ScrollView>



    </RelativeLayout>

</layout>