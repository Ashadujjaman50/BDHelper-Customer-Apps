<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_color"
        style="@style/fontStyle"
        tools:context=".userFragment.partner.paymentFragment.PaymentWithdrawFragment">

        <!-- RecycleView Withdraw List -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_color"
            android:paddingHorizontal="2dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/paymentAccountRv"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/row_withdraw_request" />

            <TextView
                android:id="@+id/noPaymentAccountFound"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/no_withdraw_request_found"
                android:textColor="@color/text_secondary"
                android:textSize="22sp"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/withdrawPaymentButton"
            android:layout_width="wrap_content"
            android:layout_height="50dp"
            android:layout_margin="24dp"
            android:padding="15dp"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:background="@drawable/custom_button_gradient"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/withdraw_request"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:drawablePadding="12dp"
            app:drawableStartCompat="@drawable/ic_payment_withdraw"
            app:drawableTint="@color/white" />


    </RelativeLayout>

</layout>