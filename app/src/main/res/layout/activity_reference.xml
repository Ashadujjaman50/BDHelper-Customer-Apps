<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".ReferenceActivity">

        <RelativeLayout
            style="@style/fontStyle"
            android:background="@color/bg_color"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!--Toolbar-->
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:elevation="1dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/backBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:padding="12dp"
                        app:srcCompat="@drawable/ic_back_arrow"
                        app:tint="@color/icon_color" />

                    <TextView
                        android:id="@+id/title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/backBtn"
                        android:layout_centerVertical="true"
                        android:text="@string/refer_a_friend"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:textSize="16sp" />

                </RelativeLayout>

            </androidx.appcompat.widget.Toolbar>


            <ScrollView
                android:layout_below="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:fillViewport="true">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">


                    <!-- Subtitle -->
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Celebrate friendship. Send your friends free services and get free services for yourself too."
                        android:textSize="16sp"
                        android:lineSpacingExtra="2dp"
                        android:textColor="@color/text_primary"/>

                    <!-- Illustration -->
                    <ImageView
                        android:id="@+id/illustration"
                        android:layout_width="match_parent"
                        android:layout_height="260dp"
                        android:layout_marginTop="24dp"
                        android:src="@drawable/ic_refer_bg"
                        android:scaleType="fitCenter"/>

                    <!-- Refer ID Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your refer ID"
                        android:textSize="14sp"
                        android:layout_marginTop="24dp"
                        android:textColor="@color/text_primary"/>

                    <!-- Refer ID + Copy Button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/referIdTv"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="5dp"
                            android:gravity="center"
                            android:background="@drawable/bg_dashed_border"
                            android:hint="CODE"
                            android:textStyle="bold"
                            android:textSize="17sp"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:id="@+id/copyBtn"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:textAllCaps="true"
                            android:layout_marginStart="5dp"
                            android:elevation="2dp"
                            android:background="@drawable/bg_outline_border"
                            android:clickable="true"
                            android:focusable="true"
                            android:gravity="center"
                            android:text="COPY TEXT"
                            android:textColor="@color/primaryColor"
                            android:textStyle="bold"
                            android:textSize="16sp"/>

                    </LinearLayout>

                    <!-- Share Button -->
                    <TextView
                        android:id="@+id/shareNowBtn"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="25dp"
                        android:layout_marginBottom="5dp"
                        android:elevation="2dp"
                        android:background="@drawable/custom_button_gradient"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:text="SHARE NOW"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:textAllCaps="false"
                        android:textSize="16sp"/>

                </LinearLayout>
            </ScrollView>


        </RelativeLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>