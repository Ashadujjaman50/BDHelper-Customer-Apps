<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".user.AddressBookActivity">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            style="@style/fontStyle"
            android:background="@color/bg_color">

            <!--Toolbar-->
            <RelativeLayout
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/bg_color"
                android:elevation="2dp">

                <ImageView
                    android:id="@+id/backBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="15dp"
                    android:padding="10dp"
                    app:srcCompat="@drawable/ic_back_arrow"
                    app:tint="@color/icon_color" />

                <TextView
                    android:id="@+id/subCategoryNameTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_toEndOf="@+id/backBtn"
                    android:layout_centerVertical="true"
                    android:text="@string/address_book"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <ImageButton
                    android:id="@+id/addAddressBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@string/app_name"
                    android:padding="10dp"
                    android:background="@drawable/bg_card_clickable"
                    app:srcCompat="@drawable/ic_add_20"
                    app:tint="@color/icon_color" />

            </RelativeLayout>

            <!--Address List Layout-->
            <RelativeLayout
                android:id="@+id/addressListRl"
                android:visibility="visible"
                android:layout_below="@+id/toolbar"
                android:padding="8dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/addressListRv"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingBottom="25dp"
                    android:clipToPadding="true"
                    tools:listitem="@layout/row_address_book_item"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>


                <RelativeLayout
                    android:id="@+id/noAddressRl"
                    android:visibility="visible"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/bg_color"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_centerInParent="true"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:orientation="vertical">

                        <!-- Illustration -->
                        <ImageView
                            android:id="@+id/emptyImage"
                            android:layout_width="wrap_content"
                            android:layout_height="220dp"
                            android:src="@drawable/ic_empty"
                            android:contentDescription="@string/app_name"
                            android:layout_marginBottom="10dp" />

                        <!-- Title -->
                        <TextView
                            android:id="@+id/emptyTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="অ্যাড্রেস সেভ করা নেই"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="8dp" />

                        <!-- Subtitle -->
                        <TextView
                            android:id="@+id/emptySubtitle"
                            android:layout_marginTop="5dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="নতুন অ্যাড্রেস যোগ করুন এবং সহজেই খুঁজে নিন আপনার পছন্দের অ্যাড্রেস"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:gravity="center"
                            android:layout_marginBottom="24dp" />

                    </LinearLayout>


                    <!-- Bottom Button -->
                    <Button
                        android:id="@+id/addAddressNewBtn"
                        android:layout_alignParentBottom="true"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="নতুন অ্যাড্রেস যোগ করুন"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:backgroundTint="@color/primaryMid"
                        android:layout_marginBottom="12dp"
                        android:padding="12dp" />

                </RelativeLayout>


            </RelativeLayout>

            <!--Address Save Layout-->
            <LinearLayout
                android:id="@+id/addressSaveLL"
                android:visibility="gone"
                android:layout_below="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <!-- Location Info -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:padding="8dp"
                        android:background="@drawable/bg_circle_white"
                        android:src="@drawable/ic_location_outline"
                        app:tint="@color/primaryMid" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/showGetAddressTitleTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bahadurpur"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:id="@+id/showGetAddressTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="দুর্গাপুর, আষ্পগঞ্জ, ব্রাহ্মণবাড়িয়া"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Input Fields -->
                <LinearLayout
                    android:layout_marginBottom="25dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Place Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="জায়গার নাম"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/addressNameEt"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="জায়গার নাম"
                        android:background="@drawable/bg_edit_text"
                        android:padding="12dp" />

                    <!-- Recipient Mobile -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="পণ্য গ্রহীতার মোবাইল নাম্বার (অপশনাল)"
                        android:layout_marginTop="16dp"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:background="@drawable/bg_edit_text">

                        <EditText
                            android:id="@+id/recipientMobileEt"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:hint="পণ্য গ্রহীতার মোবাইল নাম্বার"
                            android:inputType="phone"
                            android:padding="12dp"
                            android:layout_toStartOf="@id/btnContacts"
                            android:background="@android:color/transparent" />

                        <ImageButton
                            android:id="@+id/btnContacts"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_contact_book"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            app:tint="@color/gray" />
                    </RelativeLayout>

                    <!-- Recipient Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="পণ্য গ্রহীতার নাম (অপশনাল)"
                        android:layout_marginTop="16dp"
                        android:textColor="@android:color/black"
                        android:textSize="14sp"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/recipientNameEt"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="পণ্য গ্রহীতার নাম"
                        android:background="@drawable/bg_edit_text"
                        android:padding="12dp" />

                </LinearLayout>

                <!-- Save Button -->
                <TextView
                    android:id="@+id/saveAddressBookBtn"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_margin="10dp"
                    android:background="@drawable/custom_button_gradient"
                    android:maxLength="24"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="@string/save"
                    android:textColor="@color/white"
                    android:textSize="16sp"/>

            </LinearLayout>



        </RelativeLayout>



    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>