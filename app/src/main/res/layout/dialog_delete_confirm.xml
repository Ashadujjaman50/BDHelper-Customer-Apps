<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/background_dialog"
    app:cardCornerRadius="10dp"
    app:cardElevation="8dp">

    <RelativeLayout
        android:padding="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iconOnly"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginEnd="5dp"
            android:layout_marginBottom="5dp"
            android:padding="8dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/red" />

        <!-- Title Text -->
        <TextView
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@+id/iconOnly"
            android:text="@string/delete"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginVertical="8dp" />

        <!-- Message Text -->
        <TextView
            android:id="@+id/message"
            android:layout_below="@+id/title"
            android:layout_toEndOf="@+id/iconOnly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Are you sure you want to delete?"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingExtra="4dp" />

        <!-- Button Container -->
        <LinearLayout
            android:id="@+id/button_container"
            android:layout_below="@+id/iconOnly"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <!-- Log Out Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_yes"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/delete"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@drawable/bg_card_clickable"
                android:paddingHorizontal="16dp"
                app:backgroundTint="#F44336"
                android:layout_marginEnd="12dp"
                app:cornerRadius="8dp"
                style="@style/Widget.MaterialComponents.Button" />

            <!-- Cancel Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/cancel"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:background="@drawable/bg_card_clickable"
                android:paddingHorizontal="16dp"
                app:backgroundTint="#E4E4E4"
                app:cornerRadius="8dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>

    </RelativeLayout>

</androidx.cardview.widget.CardView>