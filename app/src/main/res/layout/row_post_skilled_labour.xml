<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginTop="16dp"
    app:cardCornerRadius="6dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/order_card_bg_color"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Date/Time -->
            <TextView
                android:id="@+id/postTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/black"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="আজকে, সকাল ৯ টা"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Capacity -->
            <LinearLayout
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:layout_marginTop="3dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/postImage"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginEnd="4dp"
                    app:srcCompat="@drawable/ic_transport"
                    app:tint="@color/icon_color" />

                <TextView
                    android:id="@+id/postName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="ড্রাইভার"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/quantity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="১ জন"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />


            </LinearLayout>

        </RelativeLayout>

        <!-- Middle Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginHorizontal="10dp"
            android:orientation="horizontal">

            <!-- Location Section -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">


                <!-- Connector Line -->
                <LinearLayout
                    android:id="@+id/locationAreaLl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/ic_load_location" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/locationNameTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:hint="আগারগাঁও"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/locationArea"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:hint=""
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/capacityTv"
                    android:visibility="gone"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="4dp"
                    android:text="২ বছর"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <!--Desc-->
                <TextView
                    android:id="@+id/postDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:paddingHorizontal="4dp"
                    android:maxLines="2"
                    android:text="@string/we_are_here_24_7_only_to_serve_you_please_call_us_16434_or_chat_with_us_for_any_quires"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    app:drawableStartCompat="@drawable/ic_note"
                    app:drawableTint="@color/icon_color"
                    android:drawablePadding="8dp"/>

                <!--Hide - Load Point -->
                <LinearLayout
                    android:id="@+id/loadAreaLl"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/ic_load_location" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/postLoadLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="আগারগাঁও"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/loadArea"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="মিরপুর, ঢাকা সিটি"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                </LinearLayout>

                <!--Hide - Unload Point -->
                <LinearLayout
                    android:id="@+id/unloadAreaLl"
                    android:visibility="gone"
                    android:layout_below="@+id/loadAreaLl"
                    android:layout_marginTop="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="@drawable/ic_unload_location" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/postUnLoadLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="সাদাপুর কাজিপাড়া"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/unLoadArea"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="বনগাঁও, সাভার"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>



            </LinearLayout>

            <!-- Goods Icons -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="2dp">

                <ImageView
                    android:id="@+id/typesIv"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    app:srcCompat="@drawable/ic_parcel"
                    app:tint="@color/icon_color" />

                <TextView
                    android:id="@+id/typesTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:maxWidth="120dp"
                    android:text="কার্টন/ প্লাস্টিক"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_margin="8dp"
            android:background="@color/divider_color" />

        <!-- Bottom Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:layout_centerVertical="true"
                android:text="বাজার দরে বিড করুন"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/bidButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_for_bid"
                android:drawablePadding="8dp"
                android:paddingHorizontal="20dp"
                android:paddingVertical="6dp"
                android:text="বিড করুন"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:drawableStartCompat="@drawable/ic_hammer"
                app:drawableTint="@color/white" />
        </RelativeLayout>

    </LinearLayout>

    <LinearLayout
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="28dp"
            android:layout_marginEnd="5dp"
            android:scaleType="fitCenter"
            app:srcCompat="@drawable/ic_home_shift"
            app:tint="@color/icon_color" />

        <TextView
            android:id="@+id/orderIdTv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingVertical="5dp"
            android:text=""
            android:textSize="16sp"
            android:textStyle="bold" />



    </LinearLayout>

</androidx.cardview.widget.CardView>
