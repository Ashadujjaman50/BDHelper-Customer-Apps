<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    >
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".sharedActivity.RatingReviewActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_color"
            android:orientation="vertical">

            <!--Toolbar-->
            <RelativeLayout
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/bg_toolbar_color"
                android:elevation="2dp">

                <ImageView
                    android:id="@+id/backBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="15dp"
                    android:padding="10dp"
                    app:srcCompat="@drawable/ic_back_arrow"
                    app:tint="@color/icon_color" />

                <TextView
                    android:id="@+id/appBarTitleTV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_toEndOf="@+id/backBtn"
                    android:layout_centerVertical="true"
                    android:text="@string/your_rating_review"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="17sp" />



            </RelativeLayout>


            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="10dp">

                    <!-- Rating Summary Card -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/ratingSummaryCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="6dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:id="@+id/ratingSummaryLayout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:paddingVertical="@dimen/gmp_ref_measurement_spacing_16"
                            android:paddingHorizontal="10dp">

                            <!-- Average Rating -->
                            <TextView
                                android:id="@+id/averageRatingTv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center_vertical"
                                android:layout_marginEnd="32dp"
                                android:layout_marginStart="12dp"
                                android:text="৫.০"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary"
                                android:gravity="center_vertical"
                                app:drawableStartCompat="@drawable/ic_star_rate_24"
                                android:drawablePadding="8dp" />


                            <!-- Rating Distribution -->
                            <LinearLayout
                                android:id="@+id/ratingDistributionLayout"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <!-- 5 star -->
                                <LinearLayout
                                    android:id="@+id/fiveStarLayout"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/fiveStarLabelTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="৫ ⭐"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"/>

                                    <ProgressBar
                                        android:id="@+id/fiveStarProgress"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="0dp"
                                        android:layout_height="8dp"
                                        android:layout_weight="1"
                                        android:progress="100"
                                        android:progressTint="@color/primaryColor"
                                        android:layout_marginHorizontal="8dp"/>

                                    <TextView
                                        android:id="@+id/fiveStarPercentTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="১০০%"
                                        android:textSize="12sp"
                                        android:textColor="@color/text_primary"/>
                                </LinearLayout>

                                <!-- 4 star -->
                                <LinearLayout
                                    android:id="@+id/fourStarLayout"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/fourStarLabelTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="৪ ⭐"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"/>

                                    <ProgressBar
                                        android:id="@+id/fourStarProgress"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="0dp"
                                        android:layout_height="8dp"
                                        android:layout_weight="1"
                                        android:progress="0"
                                        android:progressTint="#B71C1C"
                                        android:layout_marginHorizontal="8dp"/>

                                    <TextView
                                        android:id="@+id/fourStarPercentTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="০%"
                                        android:textSize="12sp"
                                        android:textColor="@color/text_primary"/>
                                </LinearLayout>

                                <!-- 3 star -->
                                <LinearLayout
                                    android:id="@+id/threeStarLayout"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/threeStarLabelTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="৩ ⭐"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"/>

                                    <ProgressBar
                                        android:id="@+id/threeStarProgress"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="0dp"
                                        android:layout_height="8dp"
                                        android:layout_weight="1"
                                        android:progress="0"
                                        android:progressTint="#B71C1C"
                                        android:layout_marginHorizontal="8dp"/>

                                    <TextView
                                        android:id="@+id/threeStarPercentTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="০%"
                                        android:textSize="12sp"
                                        android:textColor="@color/text_primary"/>
                                </LinearLayout>

                                <!-- 2 star -->
                                <LinearLayout
                                    android:id="@+id/twoStarLayout"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/twoStarLabelTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="২ ⭐"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"/>

                                    <ProgressBar
                                        android:id="@+id/twoStarProgress"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="0dp"
                                        android:layout_height="8dp"
                                        android:layout_weight="1"
                                        android:progress="0"
                                        android:progressTint="#B71C1C"
                                        android:layout_marginHorizontal="8dp"/>

                                    <TextView
                                        android:id="@+id/twoStarPercentTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="০%"
                                        android:textSize="12sp"
                                        android:textColor="@color/text_primary"/>
                                </LinearLayout>

                                <!-- 1 star -->
                                <LinearLayout
                                    android:id="@+id/oneStarLayout"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical">

                                    <TextView
                                        android:id="@+id/oneStarLabelTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="১ ⭐"
                                        android:textSize="14sp"
                                        android:textColor="@color/text_primary"/>

                                    <ProgressBar
                                        android:id="@+id/oneStarProgress"
                                        style="?android:attr/progressBarStyleHorizontal"
                                        android:layout_width="0dp"
                                        android:layout_height="8dp"
                                        android:layout_weight="1"
                                        android:progress="0"
                                        android:progressTint="#B71C1C"
                                        android:layout_marginHorizontal="8dp"/>

                                    <TextView
                                        android:id="@+id/oneStarPercentTv"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="০%"
                                        android:textSize="12sp"
                                        android:textColor="@color/text_primary"/>
                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </androidx.cardview.widget.CardView>

                    <!-- Filter Section -->
                    <LinearLayout
                        android:id="@+id/filterSectionLayout"
                        android:layout_marginTop="12dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/yourReviewCountTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="আপনার রিভিউ (০)"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"/>

                        <TextView
                            android:id="@+id/sortTv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical|end"
                            android:text="নতুন থেকে পুরানো"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            app:drawableEndCompat="@drawable/ic_sort"
                            android:drawablePadding="4dp"/>

                    </LinearLayout>

                    <!-- Filter Chips -->
                    <HorizontalScrollView
                        android:id="@+id/filterScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:overScrollMode="never"
                        android:layout_marginTop="8dp">

                        <LinearLayout
                            android:id="@+id/filterButtonContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/allFilterBtn"
                                android:layout_width="75dp"
                                android:layout_height="wrap_content"
                                android:text="সব"
                                android:textSize="12sp"
                                android:backgroundTint="@color/primaryMid"
                                android:textColor="#FFFFFF"
                                android:layout_marginEnd="8dp"/>

                            <Button
                                android:id="@+id/fiveStarFilterBtn"
                                android:layout_width="75dp"
                                android:layout_height="wrap_content"
                                android:text="৫ ⭐"
                                android:textSize="12sp"
                                android:backgroundTint="#F0F0F0"
                                android:textColor="#000"
                                android:layout_marginEnd="8dp"/>

                            <Button
                                android:id="@+id/fourStarFilterBtn"
                                android:layout_width="75dp"
                                android:layout_height="wrap_content"
                                android:text="৪ ⭐"
                                android:textSize="12sp"
                                android:backgroundTint="#F0F0F0"
                                android:textColor="#000"
                                android:layout_marginEnd="8dp"/>

                            <Button
                                android:id="@+id/threeStarFilterBtn"
                                android:layout_width="75dp"
                                android:layout_height="wrap_content"
                                android:text="৩ ⭐"
                                android:textSize="12sp"
                                android:backgroundTint="#F0F0F0"
                                android:textColor="#000"
                                android:layout_marginEnd="8dp"/>

                            <Button
                                android:id="@+id/twoStarFilterBtn"
                                android:layout_width="75dp"
                                android:layout_height="wrap_content"
                                android:text="২ ⭐"
                                android:textSize="12sp"
                                android:backgroundTint="#F0F0F0"
                                android:textColor="#000"
                                android:layout_marginEnd="8dp"/>

                            <Button
                                android:id="@+id/oneStarFilterBtn"
                                android:layout_width="75dp"
                                android:layout_height="wrap_content"
                                android:text="১ ⭐"
                                android:textSize="12sp"
                                android:backgroundTint="#F0F0F0"
                                android:textColor="#000"
                                android:layout_marginEnd="8dp"/>
                        </LinearLayout>
                    </HorizontalScrollView>


                    <!-- Empty State -->
                    <LinearLayout
                        android:id="@+id/reviewLl"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="40dp">

                        <ImageView
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_no_message" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="কোনো রিভিউ নেই"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="রিভিউ পেতে, আজই ট্রিপ নিন"
                            android:textSize="14sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/reviewRv"
                        app:stackFromEnd="true"
                        app:reverseLayout="true"
                        tools:listitem="@layout/row_review_layout"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>

                </LinearLayout>
            </ScrollView>

            <!-- Bottom Button -->

            <TextView
                android:id="@+id/takeTripBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_margin="15dp"
                android:background="@drawable/custom_button_gradient"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="ট্রিপ নিন"
                android:textColor="@color/white"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/getTripBtn"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_margin="15dp"
                android:background="@drawable/custom_button_gradient"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="ট্রিপ ধরুণ"
                android:textColor="@color/white"
                android:textSize="16sp"/>

        </LinearLayout>


    </androidx.coordinatorlayout.widget.CoordinatorLayout>
</layout>