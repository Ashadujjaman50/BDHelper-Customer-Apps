<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true"
        tools:context=".ProfileActivity">

        <RelativeLayout
            android:background="@color/bg_color"
            style="@style/fontStyle"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!--Toolbar-->
            <RelativeLayout
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="@color/bg_toolbar_color"
                android:elevation="2dp">

                <ImageView
                    android:id="@+id/backBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="15dp"
                    android:padding="10dp"
                    app:srcCompat="@drawable/ic_back_arrow"
                    app:tint="@color/icon_color" />

                <TextView
                    android:id="@+id/titleTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:layout_toEndOf="@+id/backBtn"
                    android:layout_centerVertical="true"
                    android:text="@string/profile"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:textSize="17sp" />

            </RelativeLayout>


            <LinearLayout
                android:layout_below="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:padding="20dp"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="130dp"
                    android:layout_height="130dp"
                    android:layout_gravity="center_horizontal">


                    <!-- Profile Image -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/userProfilePicIV"
                        android:layout_width="130dp"
                        android:layout_height="130dp"
                        android:padding="1dp"
                        android:src="@drawable/ic_profile"
                        android:background="@color/primary_light"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/ImageStyle_Circle"
                        android:layout_marginVertical="0dp"/>

                    <ImageView
                        android:id="@+id/openGalleryToLoadImage"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:layout_alignParentEnd="true"
                        android:layout_alignParentBottom="true"
                        android:layout_marginEnd="2dp"
                        android:layout_marginBottom="2dp"
                        android:padding="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_circle_white"
                        android:src="@drawable/ic_camera"
                        app:tint="@color/gray" />

                </RelativeLayout>


                <LinearLayout
                    android:layout_marginTop="24dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RelativeLayout
                        android:id="@+id/profileRL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/profileIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_profile"
                            app:tint="@color/black" />

                        <TextView
                            android:id="@+id/userNameTV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/profileIcon"
                            android:background="@color/transparent"
                            android:hint="@string/name"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/onlinePaymentRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/creditIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_call_outline"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:id="@+id/userMobileTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/creditIcon"
                            android:background="@color/transparent"
                            android:hint="@string/mobile_number"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />


                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/emailRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/emailIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_mail"
                            app:tint="@color/black" />

                        <TextView
                            android:id="@+id/userEmailTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/emailIcon"
                            android:background="@color/transparent"
                            android:hint="@string/your_email"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/locationRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/kkIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_division_location"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:id="@+id/userLocationTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/kkIcon"
                            android:background="@color/transparent"
                            android:hint="@string/location"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginEnd="16dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/districtRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/mapLocationIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_location_outline"
                            app:tint="@color/black" />

                        <TextView
                            android:id="@+id/userDistrictTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/mapLocationIcon"
                            android:background="@color/transparent"
                            android:hint="@string/district"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </RelativeLayout>


                </LinearLayout>

            </LinearLayout>


            <LinearLayout
                android:theme="@style/fontStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:layout_alignParentBottom="true"
                android:layout_centerHorizontal="true"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/documentBtn"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="10dp"
                    android:padding="12dp"
                    android:background="@drawable/bg_button_stroke_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="@string/document"
                    android:textAlignment="center"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/editBtn"
                    android:layout_width="150dp"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:background="@drawable/bg_button_stroke_primary"
                    android:clickable="true"
                    android:focusable="true"
                    android:text="@string/edit_profile"
                    android:textAlignment="center"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

        </RelativeLayout>

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

</layout>