<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/fontStyle"
        tools:context=".userFragment.ProfileFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_color">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@color/bg_color"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="16dp"
                android:layout_marginRight="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="2"
                    android:gravity="center">

                    <!-- Profile Image -->
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/userProfilePicIV"
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:padding="1dp"
                        android:src="@drawable/ic_profile"
                        android:background="@color/primary_light"
                        android:scaleType="centerCrop"
                        app:shapeAppearanceOverlay="@style/ImageStyle_Circle"
                        android:layout_marginVertical="10dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical">


                    <TextView
                        android:id="@+id/userNameTV"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="5dp"
                        android:hint="Username"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />


                    <TextView
                        android:id="@+id/rattingTV"
                        android:layout_width="100dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="5dp"
                        android:background="@drawable/rating_background"
                        android:gravity="center"
                        android:paddingVertical="2dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="0dp"
                        android:text="0"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        app:drawableEndCompat="@drawable/ic_arrow_right"
                        app:drawableStartCompat="@drawable/ic_star_rate_24"
                        android:drawablePadding="5dp" />


                </LinearLayout>

                <TextView
                    android:id="@+id/point_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_margin="5dp"
                    android:drawablePadding="4dp"
                    android:padding="10dp"
                    android:text="0PTS"
                    android:textColor="@color/text_primary"
                    android:gravity="center"
                    app:drawableTopCompat="@drawable/ic_bronge_reward_points" />

            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginStart="24dp"
                    android:text="@string/accountInformation"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <RelativeLayout
                        android:id="@+id/profileRL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/profileIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_profile"
                            app:tint="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/profileIcon"
                            android:background="@color/transparent"
                            android:text="@string/profile"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginHorizontal="14dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/addressBookRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/addressIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_address_book"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/addressIcon"
                            android:background="@color/transparent"
                            android:text="@string/address_book"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginStart="24dp"
                    android:text="@string/offer"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <RelativeLayout
                        android:id="@+id/promoRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/promoIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_cupon"
                            app:tint="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/promoIcon"
                            android:background="@color/transparent"
                            android:text="@string/promo"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginHorizontal="14dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/discountRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/discountIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_discount"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/discountIcon"
                            android:background="@color/transparent"
                            android:text="@string/discount"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginStart="24dp"
                    android:text="@string/settings"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <RelativeLayout
                        android:id="@+id/languageRL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/worldIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_world"
                            app:tint="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/worldIcon"
                            android:background="@color/transparent"
                            android:text="@string/language"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginHorizontal="14dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/themeRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/themeIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_theme"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:id="@+id/themeTitleTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/themeIcon"
                            android:background="@color/transparent"
                            android:text="@string/theme"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/setThemeTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="6dp"
                            android:layout_toEndOf="@id/themeTitleTv"
                            android:background="@color/transparent"
                            android:text="(System)"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginHorizontal="14dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/permissionRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/permissionIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_security"
                            app:tint="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/permissionIcon"
                            android:background="@color/transparent"
                            android:text="@string/permission"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginStart="24dp"
                    android:text="@string/legal"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <RelativeLayout
                        android:id="@+id/termsConditionRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/termsIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_terms_and_conditions"
                            app:tint="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/termsIcon"
                            android:background="@color/transparent"
                            android:text="@string/terms_and_condition"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginHorizontal="14dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/privacyPolicy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/privacyIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_privacy_policy"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/privacyIcon"
                            android:background="@color/transparent"
                            android:text="@string/privacy_policy"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginStart="24dp"
                    android:text="@string/others"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/transparent"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">


                    <RelativeLayout
                        android:id="@+id/referAppRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/referIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="7dp"
                            android:src="@drawable/ic_refer"
                            app:tint="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/referIcon"
                            android:background="@color/transparent"
                            android:text="@string/refer_a_friend"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:layout_marginHorizontal="14dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/shareAppRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/shareIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_share"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/shareIcon"
                            android:background="@color/transparent"
                            android:text="@string/share"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </RelativeLayout>

                </LinearLayout>

            </LinearLayout>

            <RelativeLayout
                android:id="@+id/logOutRl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_row_light"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="16dp"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/logoutIcon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/card_square_bg"
                    android:padding="8dp"
                    android:src="@drawable/ic_logout"
                    app:tint="@color/black" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:layout_toEndOf="@id/logoutIcon"
                    android:background="@color/transparent"
                    android:text="@string/logOut"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/transparent"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/facebookIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/card_square_light_bg"
                    android:src="@drawable/ic_facebook" />

                <ImageView
                    android:id="@+id/instagramIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/card_square_light_bg"
                    android:src="@drawable/ic_instagram" />

                <ImageView
                    android:id="@+id/twitterIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/card_square_light_bg"
                    android:src="@drawable/ic_twitter" />

                <ImageView
                    android:id="@+id/linkedinIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/card_square_light_bg"
                    android:src="@drawable/ic_linkedin" />

            </LinearLayout>

            <TextView
                android:id="@+id/applicationVersionTv"
                android:layout_width="wrap_content"
