<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/bg_color"
        style="@style/fontStyle"
        tools:context=".userFragment.HomeFragment">

        <!--Toolbar-->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?android:attr/windowBackground"
            android:elevation="1dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/logoIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_logo" />

                <TextView
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="10dp"
                    android:layout_toEndOf="@id/logoIV"
                    android:text="@string/app_name_display"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    tools:ignore="RelativeOverlap" />

                <RelativeLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="5dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_circle_white"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:id="@+id/notificationBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/transparent"
                        android:contentDescription="@string/notification"
                        android:src="@drawable/ic_notification"
                        app:tint="@color/icon_color" />

                    <TextView
                        android:id="@+id/notificationCountTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="-11dp"
                        android:layout_marginTop="2dp"
                        android:layout_toEndOf="@+id/notificationBtn"
                        android:background="@drawable/bg_circle_white"
                        android:paddingHorizontal="3dp"
                        android:text="0"
                        android:textAlignment="center"
                        android:textColor="@color/primaryColor"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:ignore="SmallSp" />

                </RelativeLayout>

            </RelativeLayout>

        </androidx.appcompat.widget.Toolbar>

        <!--Scroll-->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginHorizontal="12dp">

                <!--Image Slider-->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="1dp"
                    app:cardBackgroundColor="@color/bg_color"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="0dp">

                    <!--Demo Image view (Replace Image Slider)-->
                    <com.denzcoskun.imageslider.ImageSlider
                        android:id="@+id/image_slider"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        app:iss_auto_cycle="true"
                        app:iss_delay="1000"
                        app:iss_no_dots="true"
                        app:iss_period="2000"
                        app:iss_text_align="CENTER"
                        app:iss_title_background="@color/grey_font"
                        tools:ignore="MissingClass" />


                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:visibility="gone"
                    app:cardCornerRadius="6dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <com.smarteist.autoimageslider.SliderView
                        android:id="@+id/imageSlider"
                        android:layout_width="match_parent"
                        android:layout_height="160dp" />

                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="74dp"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:id="@+id/trendingLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_primary_light"
                            android:padding="8dp"
                            android:src="@drawable/ic_trending"
                            app:tint="@color/primaryColor" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="@string/trending"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/popularLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="8dp"
                            android:src="@drawable/ic_popular"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="@string/popular"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/promoLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="12dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_primary_light"
                            android:padding="8dp"
                            android:src="@drawable/ic_promo"
                            app:tint="@color/primaryColor"  />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:text="@string/promotion"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/recommendLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="8dp"
                            android:src="@drawable/ic_recommend"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:gravity="center"
                            android:maxLines="1"
                            android:text="@string/recommended"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="2dp"
                        android:background="@color/gray" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp"
                        android:text="@string/category"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <View
                        android:layout_width="20dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="2dp"
                        android:background="@color/gray" />

                </LinearLayout>

                <!--Service Row 1St -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    tools:ignore="UseCompoundDrawables">

                    <!--Road Transport-->
                    <LinearLayout
                        android:id="@+id/transportLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="16dp"
                            android:src="@drawable/ic_transport"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:gravity="center_horizontal"
                            android:textColor="@color/text_primary"
                            android:text="@string/road_transport" />

                    </LinearLayout>

                    <!--Harvester -->
                    <LinearLayout
                        android:id="@+id/harvesterLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="16dp"
                            android:src="@drawable/ic_harvester"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:gravity="center_horizontal"
                            android:textColor="@color/text_primary"
                            android:text="@string/harvester" />

                    </LinearLayout>

                    <!--Lo-bet-->
                    <LinearLayout
                        android:id="@+id/equipmentLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        tools:ignore="UseCompoundDrawables">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="16dp"
                            android:src="@drawable/ic_equipment"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:gravity="center_horizontal"
                            android:textColor="@color/text_primary"
                            android:text="@string/equipment" />

                    </LinearLayout>

                </LinearLayout>

                <!--Service Row 2nd -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    tools:ignore="UseCompoundDrawables">

                    <!--Lo-bet-->
                    <LinearLayout
                        android:id="@+id/loBetLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="16dp"
                            android:src="@drawable/ic_trailer"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:gravity="center_horizontal"
                            android:textColor="@color/text_primary"
                            android:text="@string/lo_bet" />

                    </LinearLayout>

                    <!--Rent A Car -->
                    <LinearLayout
                        android:id="@+id/rentCarLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="16dp"
                            android:src="@drawable/ic_car_transport"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:gravity="center_horizontal"
                            android:textColor="@color/text_primary"
                            android:text="@string/rent_a_car" />

                    </LinearLayout>

                    <!--Home Shifting-->
                    <LinearLayout
                        android:id="@+id/homeShiftingLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="16dp"
                            android:src="@drawable/ic_home_shift"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:gravity="center_horizontal"
                            android:textColor="@color/text_primary"
                            android:text="@string/home_office_shifting" />

                    </LinearLayout>

                </LinearLayout>

                <!--Service Row 3rd -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginTop="12dp"
                    android:baselineAligned="false"
                    android:orientation="horizontal"
                    android:weightSum="3"
                    tools:ignore="UseCompoundDrawables">

                    <!--Skilled Laborer-->
                    <LinearLayout
                        android:id="@+id/skilledLaborerLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="16dp"
                            android:src="@drawable/ic_skilled_labourer"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:gravity="center_horizontal"
                            android:textColor="@color/text_primary"
                            android:text="@string/skilled_labor" />

                    </LinearLayout>

                    <!--Shop-->
                    <LinearLayout
                        android:id="@+id/shopLl"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="19dp"
                            android:src="@drawable/ic_shop"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:gravity="center_horizontal"
                            android:textColor="@color/text_primary"
                            android:text="@string/shop" />

                    </LinearLayout>


                    <!--Coming soon -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="75dp"
                            android:background="@drawable/bg_gray_light"
                            android:padding="21dp"
                            android:src="@drawable/ic_coming_soon"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginTop="8dp"
                            android:gravity="center_horizontal"
                            android:textColor="@color/text_primary"
                            android:text="@string/coming_soon" />

                    </LinearLayout>

                </LinearLayout>

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:layout_marginVertical="12dp">

                    <ImageView
                        android:id="@+id/helpImageCardView"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/ic_support" />

                    <TextView
                        android:id="@+id/supportTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="20dp"
                        android:background="@null"
                        android:text="@string/support_24_hours"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/contactUsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="29dp"
                        android:background="@drawable/bg_round_button"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="@string/contact_us"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />




                </RelativeLayout>

            </LinearLayout>


        </ScrollView>


    </LinearLayout>
</layout>