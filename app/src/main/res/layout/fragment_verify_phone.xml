<?xml version="1.0" encoding="utf-8"?>
<layout>
    <FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".reserve.VerifyPhoneFragment">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp"
            style="@style/fontStyle">

            <ImageView
                android:id="@+id/logoDesignIv"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="80dp"
                android:layout_weight="2"
                android:scaleType="centerInside"
                android:src="@drawable/ic_login_design" />

            <TextView
                android:id="@+id/messageTV"
                android:layout_below="@+id/logoDesignIv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="45dp"
                android:layout_marginStart="15dp"
                android:textSize="16sp"
                android:textColor="@color/text_primary"
                android:text="@string/enter_the_otp_sent_to_your_phone"/>

            <LinearLayout
                android:id="@+id/root_otp_layout"
                android:layout_below="@+id/messageTV"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:orientation="horizontal"
                android:weightSum="6">

                <EditText
                    android:id="@+id/otp_edit_box1"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_marginRight="10dp"
                    android:gravity="center"
                    android:inputType="number"
                    android:maxLength="1"
                    android:textSize="25sp"
                    android:background="@drawable/bg_edit_text_error"/>

                <EditText
                    android:id="@+id/otp_edit_box2"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_marginRight="10dp"
                    android:gravity="center"
                    android:textSize="25sp"
                    android:inputType="number"
                    android:maxLength="1"
                    android:background="@drawable/bg_edit_text_error"/>

                <EditText
                    android:id="@+id/otp_edit_box3"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_marginRight="10dp"
                    android:gravity="center"
                    android:textSize="25sp"
                    android:inputType="number"
                    android:maxLength="1"
                    android:background="@drawable/bg_edit_text_error"/>

                <EditText
                    android:id="@+id/otp_edit_box4"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_marginRight="10dp"
                    android:gravity="center"
                    android:textSize="25sp"
                    android:inputType="number"
                    android:maxLength="1"
                    android:background="@drawable/bg_edit_text_error"/>

                <EditText
                    android:id="@+id/otp_edit_box5"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_marginRight="10dp"
                    android:gravity="center"
                    android:textSize="25sp"
                    android:inputType="number"
                    android:maxLength="1"
                    android:background="@drawable/bg_edit_text_error"/>

                <EditText
                    android:id="@+id/otp_edit_box6"
                    android:layout_weight="1"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:gravity="center"
                    android:textSize="25sp"
                    android:inputType="number"
                    android:maxLength="1"
                    android:background="@drawable/bg_edit_text_error"/>


            </LinearLayout>

            <LinearLayout
                android:id="@+id/resendLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/verifyBtn"
                android:layout_marginTop="16dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/resendText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/did_not_receive_the_otp"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/timerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="02:30"
                    android:textColor="@color/primaryColor"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/resendBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/resend_otp"
                    android:textColor="@color/primaryColor"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:visibility="gone"
                    android:clickable="true"
                    android:focusable="true"/>
            </LinearLayout>


            <TextView
                android:id="@+id/verifyBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="25dp"
                android:layout_below="@+id/root_otp_layout"
                android:background="@drawable/custom_button_gradient"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:text="@string/log_in"
                android:textColor="@color/white"
                android:textAllCaps="false"
                android:textSize="16sp"/>

        </RelativeLayout>

    </FrameLayout>
</layout>