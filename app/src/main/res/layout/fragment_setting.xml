<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_color"
        style="@style/fontStyle"
        tools:context=".partnerFragment.SettingFragment">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="@string/accountInformation"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <!-- Account Info Row -->
                    <RelativeLayout
                        android:id="@+id/accountInfoRL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/accountIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_profile"
                            app:tint="@color/icon_color"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/accountIcon"
                            android:text="@string/profile_update"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"/>

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color"/>

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="4dp"
                        android:background="@color/divider_color"/>


                    <!-- Picture/Document Update Row -->
                    <RelativeLayout
                        android:id="@+id/documentRL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/pictureIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/icon_color"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/pictureIcon"
                            android:text="@string/document"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"/>

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color"/>

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="4dp"
                        android:background="@color/divider_color"/>

                    <!-- Category Info Row -->
                    <RelativeLayout
                        android:id="@+id/categoryInfoRL"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/categoryIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_category"
                            app:tint="@color/icon_color"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/categoryIcon"
                            android:text="@string/category_change"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"/>

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color"/>

                    </RelativeLayout>


                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="@string/settings"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <RelativeLayout
                        android:id="@+id/notificationRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/notificationIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_notification"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:id="@+id/notificationTitleTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/notificationIcon"
                            android:background="@color/transparent"
                            android:text="@string/notification"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/permissionRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/permissionIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_security"
                            app:tint="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/permissionIcon"
                            android:background="@color/transparent"
                            android:text="@string/permission"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:text="@string/legal"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <RelativeLayout
                        android:id="@+id/termsConditionRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/termsIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_terms_and_conditions"
                            app:tint="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/termsIcon"
                            android:background="@color/transparent"
                            android:text="@string/terms_and_condition"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/privacyPolicy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/privacyIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_privacy_policy"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/privacyIcon"
                            android:background="@color/transparent"
                            android:text="@string/privacy_policy"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/logOutRl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_row_light"
                        android:layout_marginTop="16dp"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/logoutIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_logout"
                            app:tint="@color/black" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/logoutIcon"
                            android:background="@color/transparent"
                            android:text="@string/logOut"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                    </RelativeLayout>


                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

    </RelativeLayout>

</layout>