<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="5dp"
    android:layout_marginTop="15dp"
    android:orientation="vertical"
    app:cardBackgroundColor="@color/order_card_bg_color"
    app:cardCornerRadius="7dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/postImage"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="@string/app_name"
                android:padding="3dp"
                android:background="@drawable/custom_button_gradient"
                app:srcCompat="@drawable/ic_home_shift"
                app:tint="@color/white" />

            <TextView
                android:id="@+id/postNameTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="6dp"
                android:layout_toEndOf="@id/postImage"
                android:textStyle="bold"
                android:textSize="15sp"
                android:text="@string/home_shifting_service"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/postStatusTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:gravity="center_vertical"
                android:hint="Bidding"
                android:textStyle="bold"
                android:drawablePadding="10dp"
                app:drawableStartCompat="@drawable/ic_pending" />

        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textStyle="bold"
                android:text="Order ID: "
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/orderIdTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text=" 472485252"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="5dp"
                android:textStyle="bold"
                android:text="@string/date_dote"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/rentTimeTv"
                android:layout_marginStart="5dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="26 july 25, 10.45 am"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="@color/divider_color" />

        <TextView
            android:id="@+id/postLoadLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="House 23, Road 8, Block E, Section 1\nEidgamhat, Mirpur 1"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            app:drawableStartCompat="@drawable/ic_load_location"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/postUnLoadLocation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="House 23, Road 8, Block E, Section 1\nEidgamhat, Mirpur 1"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            app:drawableStartCompat="@drawable/ic_unload_location"
            android:textColor="@color/text_primary" />



        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="10dp"
            android:background="@color/divider_color" />

        <LinearLayout
            android:id="@+id/productTypeLL"
            android:layout_marginTop="3dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/serviceNameTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textStyle="bold"
                android:text="House"
                android:textColor="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="6dp"
                android:textStyle="bold"
                android:text="@string/type_dot"
                android:textColor="@color/text_secondary" />


            <TextView
                android:id="@+id/typesTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/bachelor_house"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/capacityTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:textSize="15sp"
                android:text="২ রুম"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <LinearLayout
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/sizeCapacityDefTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:textStyle="bold"
                android:text="@string/truck_access"
                android:textColor="@color/text_secondary" />

            <TextView
                android:id="@+id/quantityTv"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="বাসার সামনে আসবে"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/durationTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:visibility="gone"
                android:text="1 day"
                android:textColor="@color/text_primary" />

        </LinearLayout>

        <!--Hide Location/ Place-->
        <TextView
            android:id="@+id/locationNameTV"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/location_name"
            android:textSize="14sp"
            android:drawablePadding="8dp"
            android:gravity="center_vertical"
            app:drawableStartCompat="@drawable/ic_location_solid" />


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/input_layout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/detail_design"
                android:orientation="vertical">


                <TextView
                    android:id="@+id/postDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="5dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:layout_marginBottom="4dp"
                    android:background="@android:color/transparent"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>


            <TextView
                android:id="@+id/messageTV"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:layout_marginStart="40dp"
                android:background="@color/white"
                android:includeFontPadding="false"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:text="Details"
                android:textColor="@color/primaryDark" />

        </RelativeLayout>

        <!--Confirmed Vendor price and Name-->
        <LinearLayout
            android:id="@+id/confirmationLayout"
            android:layout_marginTop="5dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/detail_design"
            android:orientation="horizontal"
            android:visibility="gone">

            <TextView
                android:id="@+id/confirmVendorName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="10dp"
                android:textColor="@color/accentColor_dark"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/confirmVendorMobile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="10dp"
                android:textColor="@color/accentColor_dark"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/confirmVendorPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="5dp"
                android:padding="10dp"
                android:textColor="@color/accentColor_dark"
                android:textSize="14sp"
                android:textStyle="bold"
                app:drawableStartCompat="@drawable/ic_taka_symbol"
                app:drawableTint="@color/accentColor_dark" />

        </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="3dp"
                    android:textStyle="bold"
                    android:text="@string/date_issue"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/postedDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="26-july-25 10.45 am"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>

            <TextView
                android:id="@+id/bidOrReviewTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:paddingHorizontal="6dp"
                android:text="@string/bidding"
                android:textStyle="bold"
                android:textAlignment="center"
                android:drawablePadding="10dp"
                android:textColor="@color/text_primary"
                app:drawableEndCompat="@drawable/ic_arrow_drop_down"
                app:drawableStartCompat="@drawable/ic_hammer"
                app:drawableTint="@color/order_card_icon_color"  />

        </RelativeLayout>

    </LinearLayout>


</androidx.cardview.widget.CardView>
