<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_color"
            style="@style/fontStyle"
            tools:context=".userFragment.partner.navBarFragment.MoreFragment">

            <LinearLayout
                android:id="@+id/topPartLl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/bg_color"
                android:orientation="vertical"
                android:paddingHorizontal="2dp"
                android:paddingVertical="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="10dp"
                    android:background="@color/bg_color"
                    android:layout_marginHorizontal="16dp">

                    <LinearLayout
                        android:layout_width="90dp"
                        android:layout_height="90dp"
                        android:gravity="center">

                        <!-- Profile Image -->
                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/userProfilePicIV"
                            android:layout_width="80dp"
                            android:layout_height="80dp"
                            android:padding="1dp"
                            android:src="@drawable/ic_profile"
                            android:background="@color/primary_light"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/ImageStyle_Circle"
                            android:layout_marginVertical="10dp"/>

                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:layout_marginStart="10dp"
                        android:layout_weight="5"
                        android:orientation="vertical">


                        <TextView
                            android:id="@+id/rattingTV"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:background="@drawable/rating_background"
                            android:drawablePadding="5dp"
                            android:gravity="center"
                            android:paddingVertical="2dp"
                            android:paddingLeft="10dp"
                            android:text="0.0"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            app:drawableEndCompat="@drawable/ic_arrow_right"
                            app:drawableStartCompat="@drawable/ic_star_rate_24" />

                        <TextView
                            android:id="@+id/userNameTV"
                            android:layout_below="@+id/rattingTV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginVertical="5dp"
                            android:layout_marginHorizontal="10dp"
                            android:hint="Username"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />


                        <LinearLayout
                            android:layout_marginTop="7dp"
                            android:layout_below="@+id/rattingTV"
                            android:layout_toEndOf="@+id/userNameTV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <ImageView
                                android:id="@+id/statusPendingTV"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="3dp"
                                android:paddingBottom="4dp"
                                android:src="@drawable/ic_pending_profile"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/statusVerifiedTV"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="3dp"
                                android:paddingBottom="4dp"
                                android:src="@drawable/ic_verified"
                                android:visibility="gone"/>

                            <ImageView
                                android:id="@+id/statusNotVerifiedTV"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_marginStart="3dp"
                                android:paddingBottom="4dp"
                                android:src="@drawable/ic_reject_red"
                                android:visibility="gone"/>


                        </LinearLayout>

                        <TextView
                            android:id="@+id/mobileTV"
                            android:layout_below="@+id/userNameTV"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="10dp"
                            android:background="@color/transparent"
                            android:hint="@string/mobile_number"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />


                    </RelativeLayout>

                    <ImageView
                        android:id="@+id/settingBtn"
                        android:layout_weight="1"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:padding="4dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="5dp"
                        android:src="@drawable/ic_setting_line"
                        app:tint="@color/icon_color" />

                </LinearLayout>

                <!-- Income + Bid Section in One Card -->
                <LinearLayout
                    android:layout_marginVertical="20dp"
                    android:layout_marginHorizontal="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_clickable"
                    android:orientation="vertical"
                    android:padding="12dp"
                    android:elevation="4dp"
                    android:layout_marginBottom="10dp">

                    <!-- Income Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/transparent"
                        android:orientation="horizontal">

                        <!-- Total Income -->
                        <LinearLayout
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@color/transparent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/totalAmount"
                                android:text="০"
                                android:textSize="20sp"
                                android:textColor="@color/primaryColor"
                                android:background="@color/transparent"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:drawableStartCompat="@drawable/ic_taka_symbol"
                                app:drawableTint="@color/primaryColor"
                                android:drawablePadding="4dp" />

                            <TextView
                                android:text="@string/total_income"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:background="@color/transparent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/card_divider_color"
                            android:layout_marginVertical="4dp"/>

                        <!-- Commission -->
                        <LinearLayout
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@color/transparent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/partnerEarnTv"
                                android:text="০"
                                android:textSize="20sp"
                                android:textColor="@color/primaryColor"
                                android:background="@color/transparent"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                app:drawableStartCompat="@drawable/ic_taka_symbol"
                                app:drawableTint="@color/primaryColor"
                                android:drawablePadding="4dp"/>

                            <TextView
                                android:text="@string/partner_commission"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:background="@color/transparent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/card_divider_color"
                            android:layout_marginVertical="4dp"/>

                        <!-- Company Income -->
                        <LinearLayout
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@color/transparent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/companyEarnTv"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@color/transparent"
                                android:text="০"
                                android:textColor="@color/primaryColor"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                app:drawableStartCompat="@drawable/ic_taka_symbol"
                                app:drawableTint="@color/primaryColor"
                                android:drawablePadding="4dp" />

                            <TextView
                                android:text="@string/company_commission"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:background="@color/transparent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider Line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/card_divider_color"
                        android:layout_marginVertical="8dp" />

                    <!-- Bid Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/transparent"
                        android:orientation="horizontal">

                        <!-- Total Bid -->
                        <LinearLayout
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@color/transparent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/totalBidTv"
                                android:text="০"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primaryColor"
                                android:background="@color/transparent"
                                android:layout_marginTop="4dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="@string/total_bid"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:background="@color/transparent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/card_divider_color"
                            android:layout_marginVertical="4dp"/>

                        <!-- Confirmed Bid -->
                        <LinearLayout
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@color/transparent"
                            android:orientation="vertical"
                            android:gravity="center">

                            <TextView
                                android:id="@+id/successBidTv"
                                android:text="০"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primaryColor"
                                android:background="@color/transparent"
                                android:layout_marginTop="4dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="@string/accepted_bid"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:background="@color/transparent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="match_parent"
                            android:background="@color/card_divider_color"
                            android:layout_marginVertical="4dp"/>

                        <!-- Cancelled Bid -->
                        <LinearLayout
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@color/transparent"
                            android:orientation="vertical"
                            android:gravity="center">


                            <TextView
                                android:id="@+id/cancelBidTv"
                                android:text="০"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primaryColor"
                                android:background="@color/transparent"
                                android:layout_marginTop="4dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>

                            <TextView
                                android:text="@string/cancel_bid"
                                android:textSize="12sp"
                                android:textColor="@color/text_secondary"
                                android:background="@color/transparent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <!--Payment info-->
                <RelativeLayout
                    android:id="@+id/paymentMethodRl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_clickable"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginHorizontal="16dp"
                    android:elevation="1dp"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/creditIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/card_square_light_bg"
                        android:padding="8dp"
                        android:src="@drawable/ic_credit_card"
                        app:tint="@color/icon_color" />

                    <TextView
                        android:id="@+id/rentCategoryNameTV"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@id/creditIcon"
                        android:background="@color/transparent"
                        android:text="@string/payment_account"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@color/transparent"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/icon_color" />

                </RelativeLayout>

                <RelativeLayout
                    android:id="@+id/paymentHistoryRL"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card_clickable"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="16dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:elevation="1dp"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/profileIcon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/card_square_bg"
                        android:padding="8dp"
                        android:src="@drawable/ic_payment_receipt"
                        app:tint="@color/black" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="16dp"
                        android:layout_toEndOf="@id/profileIcon"
                        android:background="@color/transparent"
                        android:text="@string/payment_history"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp" />

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@color/transparent"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/icon_color" />

                </RelativeLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Theme &amp; Language"
                        android:layout_marginTop="8dp"
                        android:layout_marginStart="4dp"
                        android:textSize="14sp"
                        android:textColor="@color/text_primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="6dp"
                        android:layout_marginHorizontal="10dp"
                        android:background="@color/divider_color" />

                    <RelativeLayout
                        android:id="@+id/languageRL"
                        android:layout_marginTop="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_clickable"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/worldIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_light_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_world"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/worldIcon"
                            android:background="@color/transparent"
                            android:text="@string/language"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/themeRl"
                        android:layout_marginTop="10dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_card_clickable"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="8dp">

                        <ImageView
                            android:id="@+id/themeIcon"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="@drawable/card_square_bg"
                            android:padding="8dp"
                            android:src="@drawable/ic_theme"
                            app:tint="@color/black" />

                        <TextView
                            android:id="@+id/themeTitleTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/themeIcon"
                            android:background="@color/transparent"
                            android:text="@string/theme"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/setThemeTv"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="6dp"
                            android:layout_toEndOf="@id/themeTitleTv"
                            android:background="@color/transparent"
                            android:text="(System)"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@color/transparent"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/icon_color" />

                    </RelativeLayout>

                </LinearLayout>

                <!-- Refer -->
                <LinearLayout
                    android:id="@+id/shareAppLl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginHorizontal="16dp"
                    android:orientation="horizontal"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_card_clickable"
                    android:padding="10dp">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="@color/transparent"
                        android:src="@drawable/ic_share"
                        android:layout_marginEnd="10dp"
                        app:tint="@color/primaryColor" />

                    <TextView
                        android:id="@+id/referAFriend"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/transparent"
                        android:text="@string/refer_a_friend"
                        android:textColor="@color/primaryColor"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="35dp"
                android:layout_marginBottom="15dp"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/facebookIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/card_square_light_bg"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_facebook" />

                <ImageView
                    android:id="@+id/instagramIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/card_square_light_bg"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_instagram" />

                <ImageView
                    android:id="@+id/twitterIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/card_square_light_bg"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_twitter" />

                <ImageView
                    android:id="@+id/linkedinIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/card_square_light_bg"
                    android:contentDescription="@string/app_name"
                    android:src="@drawable/ic_linkedin" />

            </LinearLayout>

            <!-- App Version -->
            <TextView
                android:id="@+id/applicationVersionTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginBottom="15dp"
                android:layout_marginEnd="12dp"
                android:text="App version: 0"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />

        </LinearLayout>

    </ScrollView>

</layout>