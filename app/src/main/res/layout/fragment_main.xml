<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_color"
        style="@style/fontStyle"
        tools:context=".partnerFragment.MainFragment">


        <!--Toolbar-->
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/bg_color"
            android:fadingEdgeLength="2dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <ImageView
                    android:id="@+id/logoIV"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_logo" />

                <TextView
                    android:id="@+id/title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="10dp"
                    android:layout_toEndOf="@id/logoIV"
                    android:text="@string/app_name_display"
                    android:textSize="17sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />


                <RelativeLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="5dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_circle_white"
                    android:layout_marginEnd="16dp">

                    <ImageView
                        android:id="@+id/notificationBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/transparent"
                        android:src="@drawable/ic_notification"
                        app:tint="@color/icon_color" />

                    <TextView
                        android:id="@+id/notificationCountTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="-11dp"
                        android:layout_marginTop="2dp"
                        android:layout_toEndOf="@+id/notificationBtn"
                        android:background="@drawable/bg_circle_white"
                        android:paddingHorizontal="3dp"
                        android:text="0"
                        android:textAlignment="center"
                        android:textColor="@color/primaryColor"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:visibility="gone"/>

                </RelativeLayout>


            </RelativeLayout>

        </androidx.appcompat.widget.Toolbar>


        <ScrollView
            android:layout_below="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_color"
            android:paddingHorizontal="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Image Slider -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/bg_color">

                    <!--Demo Image view (Replace Image Slider)-->
                    <com.denzcoskun.imageslider.ImageSlider
                        android:id="@+id/image_slider"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        app:iss_auto_cycle="true"
                        app:iss_delay="1000"
                        app:iss_no_dots="true"
                        app:iss_period="2000"
                        app:iss_text_align="CENTER"
                        app:iss_title_background="@color/grey_font"
                        tools:ignore="MissingClass" />

                </androidx.cardview.widget.CardView>

                <!-- Rent Service Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_marginTop="24dp"
                    android:text="@string/rent_service"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/solaimanlipi" />

                <!-- Rent Service Cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="3dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- All Bid -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:padding="15dp"
                        android:layout_margin="5dp"
                        android:elevation="1dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_card_clickable"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_category"
                            android:scaleType="fitXY"
                            app:tint="@color/icon_color" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/all_bid"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"/>

                    </LinearLayout>

                    <!-- Confirmed Bid -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:padding="15dp"
                        android:layout_margin="5dp"
                        android:elevation="1dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_card_clickable"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_checked"
                            android:scaleType="fitXY" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/accepted_bid"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textAlignment="center" />

                    </LinearLayout>

                    <!-- Pending Bid -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:padding="15dp"
                        android:layout_margin="5dp"
                        android:elevation="1dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_card_clickable"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_pending_profile"
                            android:scaleType="fitXY" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/pending_bid"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"
                            android:textAlignment="center"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Product/Service Title -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:layout_marginStart="5dp"
                    android:text="@string/product_or_service"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/solaimanlipi" />

                <!-- Product Cards -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="5dp"
                    android:weightSum="2">

                    <LinearLayout
                        android:id="@+id/batteryLl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        android:elevation="1dp"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_card_clickable"
                        android:padding="8dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_battery_color"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/battery_exchange"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/jobCircularLl"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_margin="5dp"
                        android:elevation="1dp"
                        android:orientation="vertical"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="@drawable/bg_card_clickable"
                        android:padding="8dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="wrap_content"
                            android:layout_height="80dp"
                            android:src="@drawable/ic_login_design"
                            android:scaleType="fitCenter" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="@string/job_recruitment"
                            android:textColor="@color/text_primary"
                            android:textSize="16sp"/>
                    </LinearLayout>

                </LinearLayout>

                <!-- Job Notice Card -->
                <LinearLayout
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:elevation="1dp"
                    android:layout_marginHorizontal="5dp"
                    android:orientation="vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="@drawable/bg_card_clickable"
                    android:padding="8dp"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="80dp"
                        android:src="@drawable/ic_login_design"
                        android:scaleType="fitCenter" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="নিয়োগ / বিজ্ঞপ্তি"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:fontFamily="@font/solaimanlipi" />
                </LinearLayout>

                <!-- Help Section -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:elevation="1dp"
                    android:background="@drawable/bg_card"
                    android:layout_marginHorizontal="5dp"
                    android:layout_marginVertical="16dp">

                    <ImageView
                        android:id="@+id/helpImageCardView"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:scaleType="fitXY"
                        android:src="@drawable/ic_support" />

                    <TextView
                        android:id="@+id/supportTv"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="20dp"
                        android:background="@null"
                        android:text="@string/support_24_hours"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/contactUsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:layout_centerHorizontal="true"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="29dp"
                        android:background="@drawable/bg_round_button"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:text="@string/contact_us"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />




                </RelativeLayout>

            </LinearLayout>

        </ScrollView>

    </RelativeLayout>

</layout>