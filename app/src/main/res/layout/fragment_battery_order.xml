<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:backgroundTint="@color/bg_color"
        tools:context=".userFragment.partner.productFragment.BatteryOrderFragment">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- Order Type -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="অর্ডার টাইপ"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp" />

                <RadioGroup
                    android:id="@+id/orderTypeGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbNewBattery"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:checked="true"
                        android:background="@drawable/radio_card_selector"
                        app:buttonTint="@color/radio_button_tint"
                        android:gravity="center"
                        android:layout_marginEnd="5dp"
                        android:text="নতুন ব্যাটারি"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/rbExchange"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/radio_card_selector"
                        app:buttonTint="@color/radio_button_tint"
                        android:gravity="center"
                        android:layout_marginStart="5dp"
                        android:text="এক্সচেঞ্জ"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary" />
                </RadioGroup>

                <LinearLayout
                    android:id="@+id/newBatteryLl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Battery Name -->
                    <EditText
                        android:id="@+id/batteryNameEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_edit_text"
                        android:imeOptions="actionNext"
                        android:hint="ব্যাটারির নাম"
                        android:inputType="textPersonName"
                        android:layout_marginTop="12dp"
                        android:textSize="16sp"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                    <!-- Battery Type-->
                    <TextView
                        android:id="@+id/batteryTypeEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_edit_text"
                        android:hint="ব্যাটারি টাইপ (এসিড / ড্রাই)"
                        android:layout_marginTop="12dp"
                        android:textSize="16sp"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:drawablePadding="10dp"
                        app:drawableEndCompat="@drawable/ic_arrow_drop_down"/>


                    <!-- Battery Voltage -->
                    <TextView
                        android:id="@+id/batteryVoltageEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_edit_text"
                        android:hint="ব্যাটারির ভোল্টেজ (ভোল্ট)"
                        android:layout_marginTop="12dp"
                        android:textSize="16sp"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:drawablePadding="10dp"
                        app:drawableEndCompat="@drawable/ic_arrow_drop_down" />

                    <!-- Battery Capacity -->
                    <EditText
                        android:id="@+id/batteryCapacityEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_edit_text"
                        android:imeOptions="actionNext"
                        android:hint="ব্যাটারি ক্যাপাসিটি (mAh / Plate)"
                        android:inputType="number"
                        android:layout_marginTop="12dp"
                        android:textSize="16sp"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/oldBatteryLl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Exchange Info -->
                    <TextView
                        android:text="Exchange Information (if any)"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"/>

                    <EditText
                        android:id="@+id/oldBatteryBrandEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints=""
                        android:background="@drawable/bg_edit_text"
                        android:imeOptions="actionNext"
                        android:hint="পুরাতন ব্যাটারি ব্যান্ড নাম"
                        android:inputType="text"
                        android:layout_marginTop="12dp"
                        android:textSize="16sp"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"/>

                    <!-- Battery Type-->
                    <TextView
                        android:id="@+id/oldBatteryTypeEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints=""
                        android:background="@drawable/bg_edit_text"
                        android:hint="পুরাতন ব্যাটারি টাইপ (এসিড / ড্রাই)"
                        android:layout_marginTop="12dp"
                        android:textSize="16sp"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:drawablePadding="10dp"
                        app:drawableEndCompat="@drawable/ic_arrow_drop_down"/>

                    <TextView
                        android:id="@+id/oldBatteryVoltageEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints=""
                        android:hint="পুরাতন ব্যাটারির ভোল্টেজ (ভোল্ট)"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_edit_text"
                        android:textSize="16sp"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:drawablePadding="10dp"
                        app:drawableEndCompat="@drawable/ic_arrow_drop_down" />

                    <EditText
                        android:id="@+id/oldBatteryCapacityEt"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:autofillHints=""
                        android:background="@drawable/bg_edit_text"
                        android:imeOptions="actionNext"
                        android:hint="ব্যাটারি ক্যাপাসিটি (mAh / Plate)"
                        android:inputType="number"
                        android:padding="12dp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:textSize="16sp" />


                </LinearLayout>

                <!-- Exchange Info -->
                <TextView
                    android:text="Delivery Information"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginTop="16dp"/>

                <!-- User Info -->
                <EditText
                    android:id="@+id/userNameEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text"
                    android:padding="10dp"
                    android:imeOptions="actionNext"
                    android:hint="আপনার নাম"
                    android:inputType="textPersonName"
                    android:layout_marginTop="12dp" />

                <EditText
                    android:id="@+id/userPhoneEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_edit_text"
                    android:padding="10dp"
                    android:imeOptions="actionNext"
                    android:hint="মোবাইল নাম্বার"
                    android:inputType="phone"
                    android:layout_marginTop="12dp" />

                <EditText
                    android:id="@+id/deliveryAddressEt"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:autofillHints=""
                    android:background="@drawable/bg_edit_text"
                    android:padding="10dp"
                    android:imeOptions="actionDone"
                    android:hint="ডেলিভারির ঠিকানা"
                    android:inputType="textPostalAddress"
                    android:layout_marginTop="12dp" />

                <!-- Submit Button -->
                <Button
                    android:id="@+id/submitOrderBtn"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="অর্ডার সাবমিট করুন"
                    android:layout_margin="16dp"
                    android:backgroundTint="@color/primaryMid"
                    android:textColor="@android:color/white"
                    android:layout_marginTop="16dp"
                    android:padding="12dp" />

            </LinearLayout>
        </ScrollView>


    </RelativeLayout>
</layout>