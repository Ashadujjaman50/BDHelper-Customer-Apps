<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:layout_marginHorizontal="5dp"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="10dp">

        <TextView
            android:id="@+id/withOutPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="@string/withdraw_request"
            android:textAlignment="center"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="15dp"
            android:background="@color/divider_color" />

        <LinearLayout
            android:id="@+id/nameLl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/mobileTV"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/primary_payment_account" />

            <TextView
                android:id="@+id/accountNumberEt"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:gravity="center_vertical"
                android:background="@drawable/bg_edit_text"
                android:textSize="16sp"
                android:hint="@string/account_no"
                android:inputType="phone"
                android:paddingStart="12dp"
                android:paddingEnd="0dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                app:drawableStartCompat="@drawable/ic_mfs_bkash"
                android:drawablePadding="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/withdraw_amount" />

            <EditText
                android:id="@+id/withdrawAmountEt"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_edit_text"
                android:drawableStart="@drawable/ic_taka_symbol"
                android:drawableTint="@color/icon_color"
                android:drawablePadding="12dp"
                android:gravity="center_vertical"
                android:textSize="16sp"
                android:hint="@string/withdraw_amount"
                android:inputType="numberDecimal"
                android:paddingStart="12dp"
                android:paddingEnd="0dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

        </LinearLayout>

        <!-- ✅ Checkbox for confirming withdrawal -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <CheckBox
                android:id="@+id/withdrawConfirmCheckbox"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingStart="0dp"
                android:paddingEnd="15dp"/>

            <TextView
                android:id="@+id/primaryText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/i_confirm_this_withdrawa"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:paddingStart="6dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/submitBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="25dp"
            android:background="@drawable/custom_button_gradient"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:text="@string/submit"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:textSize="16sp" />

    </LinearLayout>

</RelativeLayout>
